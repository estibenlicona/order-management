{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "nodemon: debug",
      "type": "shell",
      "command": "nodemon",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NODE_OPTIONS": "--inspect=9229"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[nodemon\\] starting",
          "endsPattern": "Server running on port"
        }
      }
    }
  ]
}
